{
  "manifest_version": 3,
  "name": "ApplyStack – Job Saver & Resume Tailor",
  "version": "1.0",
  "description": "Save jobs from LinkedIn, Indeed & Glassdoor. Get instant ATS match scores and tailor your resume without leaving the page.",

  "action": {
    "default_popup": "popup.html",
    "default_title": "ApplyStack",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "background": {
    "service_worker": "background.js"
  },

  "side_panel": {
    "default_path": "sidebar.html"
  },

  "content_scripts": [
    {
      "matches": [
        "https://www.linkedin.com/jobs/*",
        "https://linkedin.com/jobs/*",
        "https://*.indeed.com/viewjob*",
        "https://*.indeed.com/jobs*",
        "https://www.indeed.com/viewjob*",
        "https://www.glassdoor.com/job-listing/*",
        "https://www.glassdoor.com/Jobs/*",
        "https://www.glassdoor.co.uk/job-listing/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],

  "permissions": [
    "sidePanel",
    "storage",
    "tabs",
    "activeTab"
  ],

  "host_permissions": [
    "https://www.linkedin.com/*",
    "https://linkedin.com/*",
    "https://*.indeed.com/*",
    "https://www.glassdoor.com/*",
    "https://www.glassdoor.co.uk/*"
  ]
}
