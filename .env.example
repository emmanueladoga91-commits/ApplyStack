# ─── Server ────────────────────────────────────────────────
PORT=3000
NODE_ENV=production

# ─── JWT ───────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_jwt_secret_here_at_least_32_chars

# ─── Claude AI ─────────────────────────────────────────────
# Get your key at: console.anthropic.com
CLAUDE_API_KEY=sk-ant-...

# ─── Stripe ────────────────────────────────────────────────
# Get keys at: dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Stripe Price IDs — create these in your Stripe dashboard:
#   Product: "TailorCV Pro"
#   Price 1: $9.00 / month  → copy Price ID here
#   Price 2: $79.00 / year  → copy Price ID here
STRIPE_PRICE_MONTHLY=price_...
STRIPE_PRICE_ANNUAL=price_...

# ─── App URL ───────────────────────────────────────────────
# Used for Stripe redirect URLs
APP_URL=https://tailorcv.com
